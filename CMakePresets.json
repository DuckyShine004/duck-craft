{
  "version": 3,
  "configurePresets": [
    {
      "name": "release",
      "generator": "Ninja",
      "binaryDir": "build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_SUPPRESS_DEVELOPER_WARNINGS": "TRUE",
        "CMAKE_PREFIX_PATH": {
          "type": "STRING",
          "value": "$env{FASTNOISE2_PREFIX}"
        }
      }
    },
    {
      "name": "debug",
      "generator": "Ninja",
      "binaryDir": "build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_SUPPRESS_DEVELOPER_WARNINGS": "TRUE",
        "CMAKE_PREFIX_PATH": {
          "type": "STRING",
          "value": "$env{FASTNOISE2_PREFIX}"
        }
      }
    },
    {
      "name": "profile",
      "generator": "Ninja",
      "binaryDir": "build/profile",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Profile",
        "CMAKE_SUPPRESS_DEVELOPER_WARNINGS": "TRUE",
        "CMAKE_PREFIX_PATH": {
          "type": "STRING",
          "value": "$env{FASTNOISE2_PREFIX}"
        }
      }
    }
  ]
}
